# Discord bot credentials
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
# Optional: set for guild-scoped commands (instant propagation for dev); omit for global commands
GUILD_ID=

# Channel IDs
BIRTHDAY_POST_CHANNEL=channel-id-for-birthday-messages
BD_BOT_LOG_CHANNEL=channel-id-for-audit-log

# Database (defaults to ./data/birthdays.sqlite if not set)
DB_FILE_PATH=./data/birthdays.sqlite

# Set to 'production' for JSON logging
NODE_ENV=development
